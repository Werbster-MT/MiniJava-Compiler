// ERRO: condição do 'if' é int, não boolean
// Esperado: [ERRO SEMÂNTICO] Condição do 'if' deve ser boolean, recebeu: int

class ErroIfInt {
  public static void main(String[] a) {
    System.out.println(new Teste().run());
  }
}

class Teste {
  public int run() {
    int x;
    x = 5;
    if (x)
      x = 1;
    else
      x = 2;
    return x;
  }
}
