// Testa: classDecl com 'extends' (heranca)
//        formalList com multiplos parametros (formalRest)
//        expList com multiplos args (expRest)

class TesteHeranca {
  public static void main(String[] a) {
    System.out.println(new Filho().soma(3, 4));
  }
}

class Pai {
  public int soma(int a, int b) {
    return a + b;
  }
}

class Filho extends Pai {
  public int soma(int a, int b) {
    return a + b + 1;
  }
}
